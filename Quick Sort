#include <iostream>
using namespace std;

int part(int a[], int l, int h) {
    int p = a[h], i = l;
    for (int j = l; j < h; j++)
        if (a[j] < p) swap(a[i++], a[j]);
    swap(a[i], a[h]);
    return i;
}

void qs(int a[], int l, int h) {
    if (l < h) {
        int p = part(a, l, h);
        qs(a, l, p - 1);
        qs(a, p + 1, h);
    }
}

int main() {
    int a[] = {5, 3, 8, 4, 2};
    qs(a, 0, 4);
    for (int i : a) cout << i << " ";
}
