#include <iostream>
using namespace std;

int q[5], f = -1, r = -1, n = 5;

void enq(int x) {
    if ((r+1)%n == f) return;
    if (f == -1) f = 0;
    r = (r+1)%n;
    q[r] = x;
}

void dq() {
    if (f == -1) return;
    if (f == r) f = r = -1;
    else f = (f+1)%n;
}

int main() {
    enq(1); enq(2); enq(3); enq(4);
    dq(); dq();
    enq(5); enq(6);
    for (int i = 0; i < n; i++) cout << q[i] << " ";
}
